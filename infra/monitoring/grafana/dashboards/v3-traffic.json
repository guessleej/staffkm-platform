{
  "title": "staffKM v3 — 流量與錯誤率",
  "uid": "staffkm-v3-traffic",
  "tags": ["staffkm", "v3.0"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Requests / min (all services)",
      "gridPos": {"x":0,"y":0,"w":6,"h":4},
      "targets": [{"expr":"sum(rate(http_requests_total[1m])) * 60","refId":"A"}]
    },
    {
      "type": "stat",
      "title": "Error rate (5xx)",
      "gridPos": {"x":6,"y":0,"w":6,"h":4},
      "targets": [{"expr":"sum(rate(http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 0.001)","refId":"A"}],
      "fieldConfig": {"defaults":{"unit":"percentunit","thresholds":{"mode":"absolute","steps":[{"color":"green","value":null},{"color":"yellow","value":0.01},{"color":"red","value":0.05}]}}}
    },
    {
      "type": "stat",
      "title": "Error rate (4xx)",
      "gridPos": {"x":12,"y":0,"w":6,"h":4},
      "targets": [{"expr":"sum(rate(http_requests_total{status=~\"4..\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 0.001)","refId":"A"}],
      "fieldConfig": {"defaults":{"unit":"percentunit"}}
    },
    {
      "type": "stat",
      "title": "p95 latency",
      "gridPos": {"x":18,"y":0,"w":6,"h":4},
      "targets": [{"expr":"histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))","refId":"A"}],
      "fieldConfig": {"defaults":{"unit":"s"}}
    },
    {
      "type": "timeseries",
      "title": "Requests / sec by service",
      "gridPos": {"x":0,"y":4,"w":12,"h":8},
      "targets": [{"expr":"sum(rate(http_requests_total[1m])) by (job)","legendFormat":"{{job}}","refId":"A"}]
    },
    {
      "type": "timeseries",
      "title": "Latency p50/p95/p99 (all)",
      "gridPos": {"x":12,"y":4,"w":12,"h":8},
      "targets": [
        {"expr":"histogram_quantile(0.5, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))","legendFormat":"p50","refId":"A"},
        {"expr":"histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))","legendFormat":"p95","refId":"B"},
        {"expr":"histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))","legendFormat":"p99","refId":"C"}
      ],
      "fieldConfig": {"defaults":{"unit":"s"}}
    }
  ]
}
