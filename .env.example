# ── 資料庫 ──────────────────────────────────────
DB_USER=staffkm
DB_PASSWORD=your_db_password_here
DB_NAME=staffkm

# ── Redis ────────────────────────────────────────
REDIS_PASSWORD=your_redis_password_here

# ── MinIO 物件儲存 ───────────────────────────────
MINIO_ROOT_USER=staffkm
MINIO_ROOT_PASSWORD=your_minio_password_here

# ── JWT 安全金鑰 ─────────────────────────────────
SECRET_KEY=your_very_long_secret_key_here_at_least_32_chars
JWT_EXPIRE_MINUTES=480

# ════════════════════════════════════════════════════
#  AI 模型（地端優先策略，RFC-005）
# ════════════════════════════════════════════════════
# 預設全走內網 Ollama，無需任何外部 API key 即可完整運行
# 雲端 provider 需用戶主動 opt-in 才會啟用

# ── LLM（chat / agent / workflow 預設）───────────
LLM_PROVIDER=ollama
LLM_MODEL=gemma4:e4b
LLM_BASE_URL=http://embedder:11434/v1
LLM_API_KEY=dummy
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# ── Embedding（已內網化）──────────────────────────
EMBEDDING_MODEL=bge-m3
EMBEDDING_BASE_URL=http://embedder:11434/v1
EMBEDDING_DIMENSION=1024

# ── 雲端 LLM（選用，留空則停用）────────────────────
# 啟用後需在 Model Hub UI 中選擇對應 provider 才會生效
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── LDAP / AD 整合 (可選) ─────────────────────────
LDAP_ENABLED=false
LDAP_SERVER=ldap://your-ad-server:389
LDAP_BASE_DN=DC=company,DC=com
LDAP_BIND_DN=CN=svc-staffkm,OU=ServiceAccounts,DC=company,DC=com
LDAP_BIND_PASSWORD=your_ldap_password

# ── LINE 整合 (可選) ──────────────────────────────
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ── Microsoft Teams 整合 (可選) ───────────────────
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# ── v3.3 B1: OpenTelemetry tracing（profile observability 才取消註解）
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318

# ── v3.4 P2: SMTP for quota_alert email channel（不設則 email-only alert 變 log-only）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=alerts@your-domain.com
# SMTP_PASSWORD=app-specific-password
# SMTP_FROM=alerts@your-domain.com
# SMTP_USE_TLS=true

# ── v3.4 P3: Cross-encoder reranker（profile reranker 才啟用）
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# RERANKER_DEVICE=cpu

# ── v4.6 F: 帳號 self-service flows ───────────────
# verify-email / reset-password link 用的前端 base URL
# PUBLIC_WEB_BASE_URL=http://localhost

# ── v4.6 F: Self-service OAuth (Google / GitHub) — 與企業 OIDC SSO 並行
# 申請：
#   Google : https://console.cloud.google.com/apis/credentials
#   GitHub : https://github.com/settings/developers
# Authorized redirect URIs:
#   {PUBLIC_WEB_BASE_URL}/api/v1/auth/oauth/google/callback
#   {PUBLIC_WEB_BASE_URL}/api/v1/auth/oauth/github/callback
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# ── v4.7+v4.8 G+H: Stripe billing ─────────────────
# 不設 STRIPE_SECRET_KEY → /billing/* 端點回 503，其他功能不受影響
# Test mode: https://dashboard.stripe.com/test/apikeys
# Webhook secret 從 stripe-cli `stripe listen` 或 dashboard endpoint 取得
# Price IDs 從 Stripe Dashboard 建立 Product+Price 後複製
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...      # $29/month subscription
# STRIPE_PRICE_PRO=price_...          # $199/month subscription
# STRIPE_PRICE_USAGE=price_...        # metered, $0.001/1k tokens 之類
# BILLING_PUBLIC_URL=https://your-domain.com
