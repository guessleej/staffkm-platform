# ════════════════════════════════════════════════════════════════
#  staffKM Production Environment — copy to .env.production
#  填入真實值後執行：
#    ./tools/scripts/safe-redeploy.sh --prod --all
#  (或手動)
#    docker compose --env-file .env.production \
#      -f infra/docker-compose.yml \
#      -f infra/docker-compose.production.yml \
#      --project-directory . up -d --build
# ════════════════════════════════════════════════════════════════

# ─── 公開域名（影響 Caddy auto-TLS）─────────────────
# DNS A record 必須指到此 server 才能拿到 Let's Encrypt 證書
PUBLIC_DOMAIN=staffkm.example.com
ADMIN_EMAIL=admin@example.com

# ─── 資料庫 — 使用強密碼 ─────────────────────────────
DB_USER=staffkm
DB_PASSWORD=___CHANGE_ME_TO_LONG_RANDOM___
DB_NAME=staffkm

# ─── Redis ──────────────────────────────────────────
REDIS_PASSWORD=___CHANGE_ME_TO_LONG_RANDOM___

# ─── MinIO ──────────────────────────────────────────
MINIO_ROOT_USER=staffkm
MINIO_ROOT_PASSWORD=___CHANGE_ME_AT_LEAST_8_CHARS___

# ─── JWT — 至少 32 字、純亂數 ─────────────────────────
# 生成：openssl rand -hex 32
SECRET_KEY=___CHANGE_ME_openssl_rand_hex_32___
JWT_EXPIRE_MINUTES=480

# ─── API key 加密金鑰（fernet）— ⚠ 務必設定 ─────────────
# 不設 → provider/embedding 的 api_key 以「明文 plain:」存 DB（賣存客戶 LLM key 的系統大忌）。
# 生成：openssl rand -base64 32
STAFFKM_SECRETS_KEY=___CHANGE_ME_openssl_rand_base64_32___

# ─── Grafana basic-auth + admin ─────────────────────
# Hash 生成：docker run --rm caddy:2.8-alpine caddy hash-password --plaintext 'your-pwd'
GRAFANA_BASIC_AUTH_HASH=___paste_caddy_hashed___
GRAFANA_ADMIN_PASSWORD=___CHANGE_ME___

# ═════════════════════════════════════════════════════
#  AI 模型 — 預設全走地端 Ollama
# ═════════════════════════════════════════════════════
LLM_PROVIDER=ollama
# 系統 LLM = gemma4:e4b（地端、多模態、中文佳）。
# ⚠ 硬體需求：embedder 容器需 ≥ 12 GB RAM 才載得動 gemma4（整機建議 ≥ 20 GB）。
#   RAM 不足請「擴充硬體」（本系統不降級模型）。詳見 docs/deploy/production-deploy.md。
LLM_MODEL=gemma4:e4b
LLM_BASE_URL=http://embedder:11434/v1
LLM_API_KEY=dummy
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
# embedder 容器記憶體上限（gemma4 需 ≥12g；給足即可）
EMBEDDER_MEM_LIMIT=16g

EMBEDDING_MODEL=snowflake-arctic-embed2
EMBEDDING_BASE_URL=http://embedder:11434/v1
EMBEDDING_DIMENSION=1024

# ─── 向量後端（v5.13）─────────────────────────────────
# pgvector（預設）：embedding 維度需 ≤2000 才能建 ivfflat 索引（>2000 退化成暴力全掃）。
# milvus：高維 embedding（如 Qwen3-Embedding 4096）原生 HNSW/IVF 真索引。專屬隔離三件套
#   （etcd+minio+milvus）— 需 `docker compose --profile milvus up -d` 才會起。
#   切 milvus 時通常同時把 EMBEDDING_DIMENSION 設成新模型維度（如 4096），並跑全庫重嵌。
VECTOR_BACKEND=pgvector
MILVUS_URI=http://staffkm-milvus:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=staffkm_paragraphs
# Milvus 容器記憶體上限（語料大可調高）
MILVUS_MEM_LIMIT=2g

# ─── 雲端 LLM（選用）──────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ─── 整合（選用）──────────────────────────────────────
LDAP_ENABLED=false
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# ─── OIDC SSO（v2.4-B；選用）──────────────────────────
# 啟用後 LoginView 會多一個「使用 SSO 登入」按鈕
OIDC_ENABLED=false
OIDC_DISPLAY_NAME=Google
OIDC_ISSUER=https://accounts.google.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://staffkm.example.com/api/v1/auth/oidc/callback
OIDC_SCOPES=openid email profile
OIDC_DEFAULT_ROLE=user

# ─── Production-only 設定 ─────────────────────────────
# 1. backups 預設掛 /var/lib/staffkm/backups（可被外部 cron 抓走）
# 2. log 等級調高（warning 起）
LOG_LEVEL=WARNING
