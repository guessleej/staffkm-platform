# ════════════════════════════════════════════════════════════════
#  staffKM Production Environment — copy to .env.production
#  填入真實值後執行：
#    ./tools/scripts/safe-redeploy.sh --prod --all
#  (或手動)
#    docker compose --env-file .env.production \
#      -f infra/docker-compose.yml \
#      -f infra/docker-compose.production.yml \
#      --project-directory . up -d --build
# ════════════════════════════════════════════════════════════════

# ─── 公開域名（影響 Caddy auto-TLS）─────────────────
# DNS A record 必須指到此 server 才能拿到 Let's Encrypt 證書
PUBLIC_DOMAIN=staffkm.example.com
ADMIN_EMAIL=admin@example.com

# ─── 資料庫 — 使用強密碼 ─────────────────────────────
DB_USER=staffkm
DB_PASSWORD=___CHANGE_ME_TO_LONG_RANDOM___
DB_NAME=staffkm

# ─── Redis ──────────────────────────────────────────
REDIS_PASSWORD=___CHANGE_ME_TO_LONG_RANDOM___

# ─── MinIO ──────────────────────────────────────────
MINIO_ROOT_USER=staffkm
MINIO_ROOT_PASSWORD=___CHANGE_ME_AT_LEAST_8_CHARS___

# ─── JWT — 至少 32 字、純亂數 ─────────────────────────
# 生成：openssl rand -hex 32
SECRET_KEY=___CHANGE_ME_openssl_rand_hex_32___
JWT_EXPIRE_MINUTES=480

# ─── Grafana basic-auth + admin ─────────────────────
# Hash 生成：docker run --rm caddy:2.8-alpine caddy hash-password --plaintext 'your-pwd'
GRAFANA_BASIC_AUTH_HASH=___paste_caddy_hashed___
GRAFANA_ADMIN_PASSWORD=___CHANGE_ME___

# ═════════════════════════════════════════════════════
#  AI 模型 — 預設全走地端 Ollama
# ═════════════════════════════════════════════════════
LLM_PROVIDER=ollama
# ⚠ LLM_MODEL 決定 embedder 容器要多少 RAM：
#   - gemma4:e4b（預設，多模態、品質好）→ 需 embedder ≥ 12 GB RAM
#   - 低 RAM 機（embedder < 12 GB）請改小模型，例如：
#       LLM_MODEL=qwen2.5:3b      # ~4GB、中文佳
#       LLM_MODEL=llama3.2:3b     # ~4GB
#       LLM_MODEL=gemma3:1b       # ~2GB、最省
#   embedder-init 會自動 pull 你設的 LLM_MODEL；改了要重跑 embedder-init。
LLM_MODEL=gemma4:e4b
LLM_BASE_URL=http://embedder:11434/v1
LLM_API_KEY=dummy
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
# embedder 容器記憶體上限（gemma4 需 ≥12g；換小模型可調低，如 6g）
EMBEDDER_MEM_LIMIT=16g

EMBEDDING_MODEL=bge-m3
EMBEDDING_BASE_URL=http://embedder:11434/v1
EMBEDDING_DIMENSION=1024

# ─── 雲端 LLM（選用）──────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ─── 整合（選用）──────────────────────────────────────
LDAP_ENABLED=false
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# ─── OIDC SSO（v2.4-B；選用）──────────────────────────
# 啟用後 LoginView 會多一個「使用 SSO 登入」按鈕
OIDC_ENABLED=false
OIDC_DISPLAY_NAME=Google
OIDC_ISSUER=https://accounts.google.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://staffkm.example.com/api/v1/auth/oidc/callback
OIDC_SCOPES=openid email profile
OIDC_DEFAULT_ROLE=user

# ─── Production-only 設定 ─────────────────────────────
# 1. backups 預設掛 /var/lib/staffkm/backups（可被外部 cron 抓走）
# 2. log 等級調高（warning 起）
LOG_LEVEL=WARNING
